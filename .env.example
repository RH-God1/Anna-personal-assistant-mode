PORT=3000
CONTROLLED_API_PORT=4318
DATABASE_URL=postgres://anna:anna@127.0.0.1:5432/anna_controlled_assistant
REDIS_URL=redis://127.0.0.1:6379
PLAYWRIGHT_HEADLESS=true
ANNA_ALLOWED_SHORTCUTS=
PROVIDER_MODE=mock
LOCAL_ENVELOPE_MASTER_KEY=

# Rate limits. Current local implementation is in-memory; production must use Redis.
RATE_LIMIT_USER_CAPACITY=60
RATE_LIMIT_USER_REFILL_PER_SECOND=1
RATE_LIMIT_TENANT_CAPACITY=300
RATE_LIMIT_TENANT_REFILL_PER_SECOND=5
RATE_LIMIT_PROVIDER_CAPACITY=500
RATE_LIMIT_PROVIDER_REFILL_PER_SECOND=8
USAGE_USER_DAILY_QUOTA=1000
USAGE_TENANT_DAILY_QUOTA=10000
SEARCH_CACHE_TTL_MS=300000

# Duffel
DUFFEL_BASE_URL=https://api.duffel.com
DUFFEL_ACCESS_TOKEN=
DUFFEL_STAYS_ENABLED=false

# Future travel supplier placeholders. Disabled in this Duffel-only phase.
