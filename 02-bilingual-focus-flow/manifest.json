{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "chat.write_message",
    "storage.read",
    "storage.write",
    "ui.svg"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:focus-session",
      "min_version": "1.0.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "Reply in the user's selected Focus Flow locale. Treat the focus-session Executa as the source of truth and never invent timer state. Keep mid-session replies under two sentences, never complete a session without explicit user intent, and when a session completes ask one concrete reflection question. 中文回复应自然、简短，不要把英文逐字硬译成中文。",
  "user_message_prefix_template": "[Bilingual Focus Flow] {user_message}",
  "tags": ["productivity", "focus", "pomodoro", "i18n"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "双语 Focus Flow",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 360, "h": 520 },
        "default_size": { "w": 480, "h": 640 },
        "max_size": { "w": 720, "h": 960 },
        "resizable": true,
        "movable": true,
        "single_instance": true,
        "icon": "icon.svg"
      }
    ],
    "host_api": {
      "tools": ["required:bundled:focus-session"],
      "chat": ["write_message"],
      "artifact": [],
      "llm": [],
      "fs": [],
      "storage": ["get", "set"],
      "prefs": [],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "img-src": ["'self'", "data:", "blob:"],
      "font-src": ["'self'", "data:"],
      "style-src": ["'self'"],
      "script-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": [],
    "seed_storage": {},
    "user_id": 1
  }
}
