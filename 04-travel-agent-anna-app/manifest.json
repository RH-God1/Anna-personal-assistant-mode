{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "chat.write_message",
    "ui.svg"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:travel-agent",
      "min_version": "1.0.0",
      "version": "latest"
    }
  ],
  "optional_executas": [],
  "system_prompt_addendum": "Use the travel-agent tool only for non-personal itinerary fields. Never request or transmit names, identity documents, phone numbers, payment cards, verification codes, or payment passwords. Traveler details, order confirmation, and payment require the user.",
  "user_message_prefix_template": "[Private Travel Agent] {user_message}",
  "tags": ["travel", "privacy", "human-in-the-loop"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "隐私旅行代理",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 380, "h": 560 },
        "default_size": { "w": 680, "h": 760 },
        "max_size": { "w": 980, "h": 1080 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": ["required:bundled:travel-agent"],
      "chat": ["write_message"],
      "artifact": [],
      "llm": [],
      "fs": [],
      "storage": [],
      "prefs": [],
      "window": ["set_title"]
    },
    "csp_overrides": {
      "img-src": ["'self'", "data:"],
      "font-src": ["'self'", "data:"],
      "style-src": ["'self'"],
      "script-src": ["'self'"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": [],
    "seed_storage": {},
    "user_id": 1
  }
}
