# Anna Personal Assistant travel booking sandbox configuration.
# Copy to .env for local development. Never commit real API keys.

PORT=8808
HOST=127.0.0.1

# Duffel Flights/Stays API. First phase uses sandbox/test mode and never pays.
DUFFEL_ACCESS_TOKEN=
DUFFEL_BASE_URL=https://api.duffel.com
DUFFEL_TEST_MODE=true
DUFFEL_STAYS_ENABLED=false

# Future provider placeholders. Disabled in this Duffel-only phase.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_ENV=test
AMADEUS_TEST_MODE=true
HOTELBEDS_API_KEY=
HOTELBEDS_SECRET=
HOTELBEDS_ENV=test
HOTELBEDS_TEST_MODE=true

# Optional HealthKit bridge token when exposing the local bridge beyond localhost.
HEALTHKIT_BRIDGE_TOKEN=
